# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project at: https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key - NEVER expose to client or commit to git
# Only use this in server-side code for privileged operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# OpenRouter: https://openrouter.ai

OPENROUTER_API_KEY=your-openrouter-key-here

# AI Model Selection
# Popular options:
# - openai/gpt-4-turbo (most capable, costs more)
# - openai/gpt-4 (very capable)
# - anthropic/claude-opus-4 (good quality)
# - openai/gpt-3.5-turbo (fast and cheap)
# - meta-llama/llama-2-70b-chat (open source)
NEXT_PUBLIC_AI_MODEL=openai/gpt-4-turbo

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# App URL - Must match your deployment domain
# Development: http://localhost:3000
# Production: https://your-domain.com or https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
# Set to 'production' for production builds

# ============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================================

NEXT_PUBLIC_ENABLE_VOICE=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_MEMORY=true

# ============================================================================
# PRODUCTION DEPLOYMENT INSTRUCTIONS
# ============================================================================

# 1. Supabase Setup:
#    a. Create project at https://supabase.com
#    b. Copy NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
#    c. Go to Authentication > URL Configuration:
#       - Site URL: https://your-domain.com
#       - Redirect URLs: https://your-domain.com/auth/callback
#    d. Run migrations: supabase db push
#
# 2. Vercel Deployment:
#    a. Connect repo to Vercel (vercel.com/new)
#    b. Go to Settings > Environment Variables
#    c. Add all required variables:
#       - NEXT_PUBLIC_SUPABASE_URL
#       - NEXT_PUBLIC_SUPABASE_ANON_KEY
#       - OPENROUTER_API_KEY
#       - NEXT_PUBLIC_APP_URL (set to production domain)
#    d. Deploy: git push or deploy from Vercel dashboard
#
# 3. Database:
#    a. Run migrations
#    b. Verify RLS policies are in place
#    c. Test signup/login flow
#
# 4. Security:
#    a. Enable HTTPS (automatic on Vercel)
#    b. Configure CORS in Supabase
#    c. Never expose service role key
#    d. Review RLS policies
#
# 5. Testing:
#    a. Test authentication flow
#    b. Test chat functionality
#    c. Verify database operations
#    d. Check error handling
#
# ============================================================================

